void initCarGame() { currentState = GAME; playerLane = 1; enemyLane = random(0, 3); enemyY = -30; gameScore = 0; gameSpeed = 12; isGameOver = false; }
void drawCarGameFramework() { tft.fillRect(0, 0, 320, 210, 0x31A6); tft.fillRect(50, 0, 160, 210, 0x4210); drawPlayerVehicle(false); drawEnemyVehicle(false); updateGameScoreUI(); }

void drawPlayerVehicle(bool er) { 
    int xp = 63 + (playerLane * 53); 
    uint16_t body = er ? 0x4210 : 0x07E0;  
    uint16_t wheel = er ? 0x4210 : 0x0000; 
    uint16_t glass = er ? 0x4210 : 0x07FF; 
    
    tft.fillRect(xp,     163, 5,  10, wheel); tft.fillRect(xp + 29, 163, 5,  10, wheel);
    tft.fillRect(xp,     190, 5,  10, wheel); tft.fillRect(xp + 29, 190, 5,  10, wheel);
    tft.fillRect(xp + 5,  160, 24, 45, body);
    tft.fillRect(xp + 10, 172, 14, 12, glass);
}

void drawEnemyVehicle(bool er) { 
    int xp = 63 + (enemyLane * 53); 
    if (enemyY <= -40 || enemyY >= 210) return;
    
    uint16_t body = er ? 0x4210 : 0xF800;  
    uint16_t wheel = er ? 0x4210 : 0x18C3; 
    uint16_t wing = er ? 0x4210 : 0xFBE0;  
    
    tft.fillRect(xp,     enemyY + 5,  5, 9, wheel); tft.fillRect(xp + 29, enemyY + 5,  5, 9, wheel);
    tft.fillRect(xp,     enemyY + 28, 5, 9, wheel); tft.fillRect(xp + 29, enemyY + 28, 5, 9, wheel);
    tft.fillRect(xp + 5,  enemyY,     24, 40, body);
    tft.fillRect(xp + 2,  enemyY + 36, 30, 4, wing); 
}

void updateGameScoreUI() { 
    tft.fillRect(215, 20, 100, 150, 0x31A6); tft.setTextColor(0xFFFF); tft.setTextSize(1); 
    tft.setCursor(225, 40); tft.print(F("SCORE:")); tft.setTextSize(2); tft.setCursor(225, 55); tft.print(gameScore); 
    tft.setTextSize(1); tft.setCursor(225, 90); tft.print(F("BEST RECORD:")); tft.setTextSize(2); tft.setCursor(225, 105); tft.print(hiRace);
}

void updateGamePhysics() {
    drawEnemyVehicle(true); enemyY += gameSpeed; 
    if (enemyY > 210) { 
        enemyY = -40; enemyLane = random(0, 3); gameScore += 10; 
        if(gameScore % 30 == 0 && gameSpeed < 26) gameSpeed += 3; 
        updateGameScoreUI(); 
    } 
    else { drawEnemyVehicle(false); }
    drawPlayerVehicle(false);
    
    if (enemyLane == playerLane && enemyY + 40 >= 160 && enemyY <= 205) { 
        isGameOver = true; 
        if (gameScore > hiRace) { hiRace = gameScore; EEPROM.put(0, hiRace); } 
        tft.fillRect(55, 65, 150, 75, 0x0000); tft.drawRect(55, 65, 150, 75, 0xFFFF); 
        tft.setTextColor(0xF800); tft.setTextSize(2); tft.setCursor(95, 75);  tft.print(F("CRASH")); 
        tft.setTextColor(0xFFFF); tft.setTextSize(1); tft.setCursor(70, 100); tft.print(F("Score: ")); tft.print(gameScore);
        tft.setCursor(70, 115); tft.print(F("Tap track to retry"));
    }
}

