// GAME 2: SNAKE GAME
// ==========================================
void initSnakeGame() { currentState = SNAKE; snakeLen = 4; snakeDir = 1; isSnakeOver = false; gameScore = 0; for(int i=0; i<snakeLen; i++) { snakeX[i] = 6 - i; snakeY[i] = 6; } spawnApple(); }
void spawnApple() { appleX = random(1, 31); appleY = random(2, 14); }
void drawSnakeGameFramework() { tft.fillRect(0, 0, 320, 160, 0x0000); tft.fillRect(0, 161, 320, 49, 0x1082); tft.setCursor(120, 165); tft.setTextColor(0xFFFF); tft.setTextSize(1); tft.print(F("SCORE: ")); tft.print(gameScore); tft.print(F("   BEST: ")); tft.print(hiSnake); }

void updateSnakePhysics() {
    tft.fillRect(snakeX[snakeLen-1] * 10, snakeY[snakeLen-1] * 10, 9, 9, 0x0000);
    for(int i = snakeLen - 1; i > 0; i--) { snakeX[i] = snakeX[i-1]; snakeY[i] = snakeY[i-1]; }
    
    if(snakeDir == 0) snakeY[0]--; if(snakeDir == 1) snakeX[0]++; if(snakeDir == 2) snakeY[0]++; if(snakeDir == 3) snakeX[0]--;
    for(int i = 1; i < snakeLen; i++) { if(snakeX[0] == snakeX[i] && snakeY[0] == snakeY[i]) { isSnakeOver = true; } }
    if(snakeX[0] < 0 || snakeX[0] > 31 || snakeY[0] < 0 || snakeY[0] > 15) { isSnakeOver = true; }
    
    if(isSnakeOver) { 
        if (gameScore > hiSnake) { hiSnake = gameScore; EEPROM.put(4, hiSnake); } 
        tft.fillRect(80, 50, 160, 55, 0xF800); tft.setTextColor(0xFFFF); tft.setTextSize(1); tft.setCursor(130, 62); tft.print(F("GAME OVER")); tft.setCursor(98, 82); tft.print(F("Tap pads to restart")); return; 
    }
    
    if(snakeX[0] == appleX && snakeY[0] == appleY) { 
        if(snakeLen < 16) snakeLen++; gameScore += 5; spawnApple(); 
        tft.fillRect(120, 165, 180, 10, 0x1082); tft.setCursor(120, 165); tft.setTextColor(0xFFFF); tft.print(F("SCORE: ")); tft.print(gameScore); tft.print(F("   BEST: ")); tft.print(hiSnake); 
    }
    
    int ax = appleX * 10, ay = appleY * 10;
    tft.fillRect(ax + 2, ay + 2, 6, 6, 0xF800);
    tft.drawPixel(ax + 4, ay + 1, 0x07E0); 
    
    for(int i = 0; i < snakeLen; i++) {
        int sx = snakeX[i] * 10, sy = snakeY[i] * 10;
        if (i == 0) {
            tft.fillRect(sx, sy, 9, 9, 0x07FF); 
            if (snakeDir == 1 || snakeDir == 3) { tft.drawPixel(sx + 4, sy + 2, 0x0000); tft.drawPixel(sx + 4, sy + 6, 0x0000); }
            else { tft.drawPixel(sx + 2, sy + 4, 0x0000); tft.drawPixel(sx + 6, sy + 4, 0x0000); }
        } else {
            tft.fillRect(sx + 1, sy + 1, 7, 7, 0x07E0); 
        }
    }
}

// ==========================================
// GAME 3: FLAPPY BIRD
// ==========================================
void initFlapGame() { currentState = FLAP; birdY = 80; birdVelocity = 0; pipeX = 320; pipeGapY = random(30, 110); gameScore = 0; isFlapOver = false; }
void drawFlapGameFramework() { tft.fillRect(0, 0, 320, 210, 0x74FF); tft.setTextColor(0xFFFF); tft.setTextSize(1); tft.setCursor(10, 10); tft.print(F("SCORE: 0   BEST: ")); tft.print(hiFlap); }

void updateFlapPhysics() {
    tft.fillRect(45, birdY - 4, 24, 20, 0x74FF);
    tft.fillRect(pipeX + 11, 0, 7, 210, 0x74FF); 

    birdVelocity += 1; birdY += birdVelocity; pipeX -= 7;

    if (pipeX < -18) {
        pipeX = 320; pipeGapY = random(30, 110); gameScore++;
        tft.fillRect(10, 10, 200, 12, 0x74FF); tft.setCursor(10, 10); tft.setTextColor(0xFFFF); tft.print(F("SCORE: ")); tft.print(gameScore); tft.print(F("   BEST: ")); tft.print(hiFlap);
    }

    if (birdY < 0 || birdY > 198) isFlapOver = true;
    if (pipeX > 26 && pipeX < 64) {
        if (birdY < pipeGapY || (birdY + 12) > (pipeGapY + pipeGapHeight)) isFlapOver = true;
    }

    if (isFlapOver) {
        if (gameScore > hiFlap) { hiFlap = gameScore; EEPROM.put(8, hiFlap); } 
        tft.fillRect(70, 70, 180, 60, 0xF800); tft.setTextColor(0xFFFF); tft.setTextSize(1);
        tft.setCursor(130, 85); tft.print(F("GAME OVER")); tft.setCursor(95, 105); tft.print(F("Tap screen to restart"));
        return;
    }

    tft.fillRect(pipeX, 0, 18, pipeGapY, 0x03E0); tft.drawRect(pipeX, 0, 18, pipeGapY, 0x0120);
    tft.fillRect(pipeX, pipeGapY + pipeGapHeight, 18, 210 - (pipeGapY + pipeGapHeight), 0x03E0); tft.drawRect(pipeX, pipeGapY + pipeGapHeight, 18, 210 - (pipeGapY + pipeGapHeight), 0x0120);
    
    int bx = 50;
    tft.fillRoundRect(bx, birdY, 14, 12, 4, 0xFEE0); 
    tft.fillRect(bx + 12, birdY + 4, 4, 4, 0xFBE0);   
    tft.drawPixel(bx + 9, birdY + 3, 0x0000);        
    
    if (birdVelocity < 0) tft.fillRect(bx + 3, birdY + 2, 5, 4, 0xFFFF); 
    else                  tft.fillRect(bx + 3, birdY + 6, 5, 4, 0xFFFF); 
}
