// NEW APP: ALARM APP 
// ==========================================
void drawAlarmApp() {
    tft.fillScreen(theme.bg);
    tft.setTextColor(theme.text);
    tft.setTextSize(2);
    tft.setCursor(20, 20);
    tft.print(F("Timer Alarm"));

    int hoursOpts[] = {5, 6, 7, 8};
    for(int i = 0; i < 4; i++) {
        uint16_t btnColor = (selectedAlarmHours == hoursOpts[i]) ? theme.accent : theme.panel;
        tft.fillRoundRect(20 + (i * 72), 60, 64, 45, 6, btnColor);
        tft.setCursor(44 + (i * 72), 75);
        tft.setTextColor(0xFFFF);
        tft.print(hoursOpts[i]);
    }

    tft.fillRoundRect(20, 130, 280, 60, 8, alarmActive ? (alarmBeeping ? 0xF800 : 0x0210) : 0x03E0); 
    tft.setCursor(35, 152);
    tft.setTextColor(0xFFFF);
    tft.setTextSize(2);
    
    if (alarmBeeping) {
        tft.print(F("STOP BUZZER BEEP"));
    } else if (alarmActive) {
        tft.print(F("CANCEL"));
        long remainingSecs = (alarmTargetTime - millis()) / 1000;
        if(remainingSecs > 0) {
            int h = remainingSecs / 3600;
            int m = (remainingSecs % 3600) / 60;
            int s = remainingSecs % 60;
            tft.setCursor(150, 152);
            if(h < 10) tft.print('0'); tft.print(h); tft.print(':');
            if(m < 10) tft.print('0'); tft.print(m); tft.print(':');
            if(s < 10) tft.print('0'); tft.print(s);
        }
    } else {
        tft.print(F("START COUNTDOWN"));
    }
}

void handleAlarmTaps(int x, int y) {
    if (y >= 60 && y <= 105 && !alarmActive) {
        for(int i = 0; i < 4; i++) {
            if (x >= 20 + (i * 72) && x <= 84 + (i * 72)) {
                selectedAlarmHours = 5 + i;
                drawAlarmApp();
                return;
            }
        }
    }
    if (x >= 20 && x <= 300 && y >= 130 && y <= 190) {
        if (alarmBeeping) {
            alarmBeeping = false;
            alarmActive = false;
            noTone(BUZZER_PIN);
        } else if (alarmActive) {
            alarmActive = false;
        } else {
            alarmTargetTime = millis() + (selectedAlarmHours * 3600000UL);
            alarmActive = true;
            alarmBeeping = false;
        }
        drawAlarmApp();
    }
}

void updateAlarmBackgroundSystem() {
    if (!alarmActive) return;
    unsigned long now = millis();
    
    if (!alarmBeeping && now >= alarmTargetTime) {
        alarmBeeping = true;
        renderCurrentState(); // Forces screen swap to display Stop Option
    }

    if (alarmBeeping) {
        if (now - lastBuzzerTick > 300) {
            lastBuzzerTick = now;
            buzzerState = !buzzerState;
            if (buzzerState) tone(BUZZER_PIN, 1300); 
            else tone(BUZZER_PIN, 1800);
        }
    }
}

