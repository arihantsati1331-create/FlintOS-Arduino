    tft.fillScreen(0xFFFF); tft.fillRect(0, 0, 320, 35, 0x2104); 
    tft.fillRect(250, 4, 65, 26, 0xF800); tft.setCursor(264, 13); tft.setTextColor(0xFFFF); tft.print(F("CLR")); 
    for(int i = 0; i < 7; i++) { 
        uint16_t c = pgm_read_word(&colorGrid[i]);
