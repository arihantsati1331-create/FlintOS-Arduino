void handleNotesCanvas(int tx, int ty) {
    if (tx >= 250 && tx <= 315 && ty >= 4 && ty <= 30) { tft.fillRect(38, 36, 282, 172, 0xFFFF); return; }
    if (tx <= 36 && ty >= 35) { 
        if (tx >= 2 && tx <= 34) {
            for(int i = 0; i < 7; i++) { 
                if(ty >= 38 + (i * 24) && ty <= 60 + (i * 24)) { 
                    currentPenColor = pgm_read_word(&colorGrid[i]); 
                } 
            }
        } return; 
    }
    if (ty > 36 && tx > 38 && tx < 318 && ty < 208) { 
        if (currentPenColor == 0xFFFF) tft.fillRect(tx - 5, ty - 5, 10, 10, 0xFFFF); 
        else tft.fillRect(tx - 1, ty - 1, 4, 4, currentPenColor); 
    }
}

void drawFlashApp() { tft.fillScreen(torchActive ? 0xFFFF : 0x2104); tft.fillRoundRect(60, 70, 200, 60, 10, torchActive ? 0x07E0 : 0xF800); tft.setTextSize(2); tft.setTextColor(0xFFFF); tft.setCursor(105, 92); tft.print(torchActive ? F("SYSTEM ON") : F("SYSTEM OFF")); }

